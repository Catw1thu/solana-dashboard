# Copy to .env.deploy on the server and replace the image tags + gRPC credentials.

# Published images for server-side deployment without source code.
GO_IMAGE=ghcr.io/your-org/solana-dashboard-go:latest
LAB_IMAGE=ghcr.io/your-org/solana-dashboard-lab:latest
MIGRATE_IMAGE=ghcr.io/your-org/solana-dashboard-migrate:latest

# Required for the Rust parser.
GRPC_ENDPOINT=https://solana-yellowstone-grpc.publicnode.com:443
GRPC_TOKEN=replace-with-your-yellowstone-token

# Optional runtime tuning.
LISTEN_SECONDS=315360000
GO_API_PORT=8081
POSTGRES_PORT=54329
REDIS_PORT=63799
NATS_PORT=4222
NATS_MONITOR_PORT=8222
