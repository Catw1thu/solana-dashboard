# =============================================================================
# Common (all environments)
# =============================================================================
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=dashboard
POSTGRES_DB=solana_dashboard

POSTGRES_PORT=54329
REDIS_PORT=63799
NATS_PORT=4222
NATS_MONITOR_PORT=8222

DATABASE_URL=postgres://dashboard:dashboard@127.0.0.1:54329/solana_dashboard?sslmode=disable
REDIS_URL=redis://127.0.0.1:63799
NATS_URL=nats://127.0.0.1:4222

# =============================================================================
# Backend (Go API)
# =============================================================================
API_ADDR=:8081
BACKEND_PORT=8081

# =============================================================================
# Parser (Rust)
# =============================================================================
GRPC_ENDPOINT=https://solana-yellowstone-grpc.publicnode.com:443
GRPC_TOKEN=replace-with-your-yellowstone-token
CAPTURE_SAMPLES=0
LISTEN_SECONDS=315360000

# =============================================================================
# Frontend (Next.js)
# =============================================================================
FRONTEND_PORT=3001
NEXT_PUBLIC_API_URL=http://127.0.0.1:8081
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8081

# =============================================================================
# Deployment images (docker-compose.deploy.yml)
# =============================================================================
BACKEND_IMAGE=ghcr.io/your-org/solana-dashboard-backend:latest
PARSER_IMAGE=ghcr.io/your-org/solana-dashboard-parser:latest
MIGRATE_IMAGE=ghcr.io/your-org/solana-dashboard-migrate:latest
FRONTEND_IMAGE=ghcr.io/your-org/solana-dashboard-frontend:latest