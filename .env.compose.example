# Copy this file to .env.compose before running docker compose.
# Required for the Rust parser.
GRPC_ENDPOINT=https://solana-yellowstone-grpc.publicnode.com:443
GRPC_TOKEN=replace-with-your-yellowstone-token

# Optional runtime tuning.
LISTEN_SECONDS=315360000
GO_API_PORT=8081
POSTGRES_PORT=54329
REDIS_PORT=63799
NATS_PORT=4222
NATS_MONITOR_PORT=8222
